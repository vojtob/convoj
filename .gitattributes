# -----------------------------------------
# Nastavenie diff/binary pre dokumentačný projekt
# (vychádza zo SIA repozitára)
# -----------------------------------------

# -----------------------------------------
# Konce riadkov – jednotné pre Windows aj Linux
# -----------------------------------------

# Textové súbory git normalizuje (v repe vždy LF)
* text=auto

# LF vynútené aj pri checkoute na Windows
*.sh       text eol=lf
*.php      text eol=lf
*.mustache text eol=lf
*.py       text eol=lf
*.js       text eol=lf
*.css      text eol=lf
*.html     text eol=lf
*.adoc     text eol=lf
*.md       text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.json     text eol=lf

# Windows skripty potrebujú CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# AsciiDoc a textové súbory: normálny diff
*.adoc text diff
*.md   text diff
*.txt  text diff
*.yaml text diff
*.yml  text diff
*.json text diff

# -----------------------------------------
# Obrázky – binárne výstupy (bez diffu)
# -----------------------------------------
*.png  binary
*.jpg  binary
*.jpeg binary
*.svg  binary
*.pdf  binary

# Generované obrázky – zvyčajne v build/
temp/* binary

# -----------------------------------------
# Zdrojové diagramy – textové formáty (chceme diff!)
# -----------------------------------------
*.drawio        text diff
*.archimate     text diff
*.archimate.xml text diff
*.puml          text diff
*.uml           text diff
*.mmd           text diff
*.uxf           text diff

# -----------------------------------------
# Voliteľné – Git LFS pre binárky
# -----------------------------------------
# *.png filter=lfs diff=lfs merge=lfs -text
# *.svg filter=lfs diff=lfs merge=lfs -text
# *.pdf filter=lfs diff=lfs merge=lfs -text
